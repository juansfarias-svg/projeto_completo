# Chave da API Groq (https://console.groq.com)
GROQ_API_KEY=seu_token_groq_aqui

# String de conexão com o PostgreSQL
DATABASE_URL=postgresql://financeiro:financeiro123@localhost:5432/financeiro

# ── Etapa 3 (RAG / Agente Inteligente) ──
# Caminho onde o índice de embeddings é salvo em cache
EMBEDDINGS_CACHE_PATH=embeddings_cache.pkl

# Modelo local de embeddings (sentence-transformers)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# URL do backend para o frontend Vite (Render)
VITE_API_URL=https://projeto-completo-1.onrender.com